# Optional: service_accounts.json is read by default from the project root.
# SERVICE_ACCOUNTS_FILE=./service_accounts.json

# Optional overrides for an OAuth client JSON file.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Required in production. Development falls back to a local-only default.
AUTH_COOKIE_SECRET=

# Only for a real service_account JSON with Google Workspace domain-wide delegation.
# GMAIL_DELEGATED_USER=user@your-workspace-domain.com
